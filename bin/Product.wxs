<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*" Name="Nexus - Desktop AI Assistant" Language="1033" Version="$(var.ProductVersion)" Manufacturer="Otectus" UpgradeCode="3FCD39F6-4965-4B51-A185-FC6E53CA431B">
    <Package InstallerVersion="500" Compressed="yes" InstallScope="perUser" InstallPrivileges="limited" />
    <MajorUpgrade AllowSameVersionUpgrades="yes" DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLDIR" />
    <Property Id="REBOOT" Value="ReallySuppress" />
    <UIRef Id="WixUI_InstallDir" />
    <WixVariable Id="WixUILicenseRtf" Value="$(var.SourceDir)\_internal\USER-LICENSE.rtf" />
    <WixVariable Id="WixUIBannerBmp" Value="$(var.SourceDir)\_internal\banner.bmp" />
    <WixVariable Id="WixUIDialogBmp" Value="$(var.SourceDir)\_internal\banner_welcome.bmp" />
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="AppDataFolder">
        <Directory Id="INSTALLDIR" Name="Nexus">
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="Nexus - Desktop AI Assistant" />
      </Directory>
      <Directory Id="DesktopFolder" Name="Desktop" />
    </Directory>
    <Feature Id="MainFeature" Title="Nexus - Desktop AI Assistant" Level="1">
      <ComponentGroupRef Id="PYGPTFiles" />
      <ComponentRef Id="ApplicationComponent" />
    </Feature>
  </Product>

  <Fragment>
    <!-- Define the icons -->
    <Icon Id="NexusIcon.ico" SourceFile="$(var.SourceDir)\_internal\icon.ico" />
    <Property Id="ARPPRODUCTICON" Value="NexusIcon.ico" />
  </Fragment>

  <Fragment>
  <DirectoryRef Id="INSTALLDIR">
    <Component Id="ApplicationComponent" Guid="9DEC9598-FA30-4CF4-8747-E6334709845D">
      <File Id="NexusExe" Source="$(var.SourceDir)\Nexus.exe" KeyPath="yes">
        <Shortcut Id="DesktopShortcut" Directory="DesktopFolder" Name="Nexus - Desktop AI Assistant" WorkingDirectory="INSTALLDIR" Icon="PyGPTIcon.ico" Advertise="yes" />
        <Shortcut Id="StartMenuShortcut" Directory="ApplicationProgramsFolder" Name="Nexus - Desktop AI Assistant" WorkingDirectory="INSTALLDIR" Icon="PyGPTIcon.ico" Advertise="yes" />
      </File>
      <RegistryValue Root="HKCU" Key="Software\[Manufacturer]\[ProductName]" Name="installed" Type="integer" Value="1"/>
    </Component>
  </DirectoryRef>
</Fragment>
</Wix>